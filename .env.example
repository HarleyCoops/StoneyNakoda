# OpenAI API key used across fine-tuning and RL grammar extraction.
# Create one here: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google API key for Gemini-powered bilingual QA generation.
# Create one here: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=your-google-api-key-here

# Purpose-specific model references.
# Do not use OPENAI_MODEL. It is ignored by current code paths.
OPENAI_CHAT_MODEL=gpt-4.1-mini-2025-04-14
OPENAI_FINETUNE_MODEL=gpt-4.1-mini-2025-04-14
OPENAI_EXTRACTION_MODEL=gpt-5
OPENAI_TASK_MODEL=gpt-5
# Vision extraction uses the older prompt-only JSON path by default, then validates locally.
STONEY_EXTRACTION_RESPONSE_FORMAT=json_prompt
STONEY_TASK_RESPONSE_FORMAT=json_schema

# Gemini defaults for bilingual QA workflows.
GEMINI_QA_MODEL=gemini-2.5-pro

# Hugging Face publishing is opt-in and private by default.
HUGGINGFACE_PUBLISH=false
HUGGINGFACE_TOKEN=hf_your-hf-token-here
HUGGINGFACE_DATASET_REPO=your-username/your-dataset-repo
HUGGINGFACE_DATASET_PRIVATE=true
# Required in addition to HUGGINGFACE_PUBLISH=true before any public dataset upload.
ALLOW_PUBLIC_DATASET_UPLOAD=false

# Weights & Biases experiment tracking (optional but recommended).
WANDB_API_KEY=your-wandb-api-key-here
WANDB_PROJECT=stoney-finetuning
# Optional organizational context for W&B.
WANDB_ENTITY=your-wandb-entity-or-team
# Optional custom run name; defaults to timestamped identifier when omitted.
WANDB_RUN_NAME=
